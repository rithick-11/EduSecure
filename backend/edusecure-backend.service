[Unit]
Description=EduSecure FastAPI Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/EduSecure/backend
Environment="PATH=/home/ubuntu/EduSecure/venv/bin"
ExecStart=/home/ubuntu/EduSecure/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
